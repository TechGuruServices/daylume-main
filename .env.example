# Required: Your PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: Port for the Express server (Defaults to 5000)
PORT=5000

# Optional: The URL to your Ollama instance (Defaults to http://localhost:11434/api/generate)
OLLAMA_URL=http://localhost:11434/api/generate

# Optional: The specific Ollama model to use (Defaults to qwen)
OLLAMA_MODEL=qwen

# Optional: How often the server checks for new RSS items in minutes (Defaults to 15)
CHECK_INTERVAL_MINUTES=15

# Telegram Notification Settings (Optional)
# Get a token from @BotFather on Telegram, and your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=8620985452:AAErFPtvEszY21A9-3jO7cdExWY3PyrjT6c
TELEGRAM_CHAT_ID=8258440957