# Supabase Configuration (Optional - for cloud sync)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Ollama Configuration (Local AI — no API key required)
# Ollama runs locally on your machine. Install from https://ollama.com
# Default model is llama3.2 — pull it with: ollama pull llama3.2
# No environment variables are required for default Ollama usage.
# The settings below are optional overrides:
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
